# ---- Laravel (backend/.env) ----
APP_KEY=
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_DATABASE=ai_church
DB_USERNAME=root
DB_PASSWORD=
REDIS_HOST=127.0.0.1
WORKER_WEBHOOK_SECRET=change-me-to-a-32-plus-character-shared-secret

# Stripe (offering segment). Webhook secret is the `whsec_...` from `stripe listen`.
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=USD
# Premium subscription price id (Stripe → Products → recurring price, `price_...`).
STRIPE_PREMIUM_PRICE_ID=price_xxx

# Subscription & token economy (all optional — sensible defaults in config/tokens.php).
TOKENS_MEMBER_MONTHLY=100        # tokens granted to members each month
TOKENS_PREMIUM_MONTHLY=1000      # tokens granted to premium each month
TOKENS_RESERVATION_TTL=30        # minutes before a stranded token hold is refunded
GUEST_TRACKING_RETENTION_DAYS=90 # how long guest one-use records are kept

# ---- Python workers ----
REDIS_URL=redis://localhost:6379/0
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=
# Optional: override the default model for generated Myanmar/Zolai text.
# Use these when the default model produces Burmese-looking but meaningless text.
LLM_MODEL_MY=
LLM_MODEL_TD=
SUNO_API_KEY=
SUNO_API_URL=https://api.suno.ai/v1
YOUTUBE_API_KEY=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ai-church-assets
S3_REGION=me-dubai-1
LARAVEL_WEBHOOK_URL=http://localhost:8000/api/internal/asset-ready
WORKER_WEBHOOK_SECRET=change-me-to-a-32-plus-character-shared-secret
# AI Bible Study — HMAC-signed worker callbacks + discussion model.
STUDY_TURN_WEBHOOK_URL=http://localhost:8000/api/internal/study-turn
STUDY_SUMMARY_WEBHOOK_URL=http://localhost:8000/api/internal/study-summary
BIBLE_STUDY_LLM_MODEL=anthropic/claude-sonnet-4-6
# Local Ollama LLM API ports (workers/api.py, two separate routers on one app)
TEDIM_LLM_URL=http://127.0.0.1:8001
BURMESE_LLM_URL=http://127.0.0.1:8002
# Ollama model names (run: ollama create <name> -f Modelfile[.burmese])
OLLAMA_MODEL_TD=tedim-zolai
OLLAMA_MODEL_MY=burmese-myanmar
# edge-tts voice overrides for English/legacy fallback. Myanmar/Tedim prefer MMS-TTS.
EDGE_TTS_VOICE_MY=my-MM-NilarNeural
EDGE_TTS_VOICE_TD=

# Native MMS speech for Myanmar/Tedim narration and Voice Studio transcript checks.
# The worker calls /tts/speak when narration_mode=mms_tts and language is my/td.
MMS_SPEECH_URL=http://127.0.0.1:8003
MMS_TTS_URL=http://127.0.0.1:8003
MMS_TTS_MODEL_MY=facebook/mms-tts-mya
MMS_TTS_MODEL_TD=facebook/mms-tts-ctd
MMS_TTS_SEED=42
# Worker→MMS read timeout. A full Bible chapter is synthesised chunk-by-chunk on
# CPU and can take several minutes on a small host; raise to 600 so the request
# completes (result is cached, so the wait only happens once per chapter/voice).
MMS_TTS_TIMEOUT=600
MMS_TTS_STAGGER_SECONDS=60
MMS_TTS_AUTO_ACTIVE=1
MMS_TTS_ACTIVE_MODELS_FILE=/opt/ai-church/backend/storage/app/voice-studio/active_models.json
MMS_ASR_MODEL=facebook/mms-1b-all
MMS_ASR_TIMEOUT=300
LOCAL_LLM_TIMEOUT=45

# Automatic Voice Studio fine-tuning. Every accepted clip refreshes
# storage/app/voice-studio/{user}/{lang}/dataset; Laravel starts one MMS/VITS
# fine-tune only during this window and only when load is below the threshold.
VOICE_TRAIN_ENABLED=true
VOICE_TRAIN_WINDOW_START=02:00
VOICE_TRAIN_WINDOW_END=06:00
VOICE_TRAIN_MAX_LOAD=2.0
VOICE_TRAIN_MIN_CLIPS=300
VOICE_TRAIN_MIN_NEW_CLIPS=25
VOICE_TRAIN_COMMAND=/opt/ai-church/workers/tools/run_mms_vits_finetune.sh
VOICE_TRAIN_EPOCHS=120
VOICE_TRAIN_BATCH_SIZE=8
VOICE_TRAIN_LEARNING_RATE=2e-5

# ---- Vue (frontend/.env) ----
VITE_API_URL=http://localhost:8000/api
VITE_STRIPE_KEY=pk_test_xxx
