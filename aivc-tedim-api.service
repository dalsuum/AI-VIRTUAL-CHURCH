[Unit]
Description=AI Church — Tedim LLM API (FastAPI/Uvicorn wrapping Ollama)
After=aivc-workers.service redis-server.service

[Service]
User=simon
WorkingDirectory=/opt/ai-church/workers
# One uvicorn worker: inference is serialized by the semaphore in tedim_router.py
# anyway, and extra workers would just compete for the same ARM CPU cores.
ExecStart=/usr/bin/env bash -lc 'set -a; . ./.env; set +a; exec .venv/bin/uvicorn api:app --host 127.0.0.1 --port 8001 --workers 1'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
