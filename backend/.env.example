APP_NAME="AI Church"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_church
DB_USERNAME=ai_church
DB_PASSWORD=

# --- Sessions / Cache ---
# Use 'cookie' (encrypted client-side, no extra storage) or 'redis' for production.
# SESSION_SECURE_COOKIE must be true in production (HTTPS); set false for local HTTP.
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
CACHE_STORE=file

# --- Queue (Redis via predis) ---
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Worker webhook ---
# Must match workers/.env and be at least 32 characters.
WORKER_WEBHOOK_SECRET=change-me-to-a-32-plus-character-shared-secret

# --- Sanctum SPA auth ---
# Comma-separated frontend origins (no scheme). Add your production domain here
# (e.g. "church.example.com"). The Vite dev server (5173) must be included locally.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8000,127.0.0.1

# --- Mail (reminder emails for scheduled services) ---
# 'log' writes each message to storage/logs/laravel.log — fine for local dev with no
# SMTP server. Switch MAIL_MAILER to 'smtp' and fill in host/credentials to deliver.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="worship@ai-church.local"
MAIL_FROM_NAME="AI Church"

# --- Frontend origin (used for links in outbound mail) ---
FRONTEND_URL=http://localhost:5173
