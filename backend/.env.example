APP_NAME="AI Church"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_church
DB_USERNAME=ai_church
DB_PASSWORD=

# --- Sessions / Cache ---
# Use 'cookie' (encrypted client-side, no extra storage) or 'redis' for production.
# SESSION_SECURE_COOKIE must be true in production (HTTPS); set false for local HTTP.
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
CACHE_STORE=file

# --- Queue (Redis via predis) ---
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Worker webhook ---
# Must match workers/.env and be at least 32 characters.
WORKER_WEBHOOK_SECRET=change-me-to-a-32-plus-character-shared-secret

# --- Sanctum SPA auth ---
# Comma-separated frontend origins (no scheme). Add your production domain here
# (e.g. "church.example.com"). The Vite dev server (5173) must be included locally.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8000,127.0.0.1

# --- Mail (reminder emails for scheduled services) ---
# 'log' writes each message to storage/logs/laravel.log — fine for local dev with no
# SMTP server. Switch MAIL_MAILER to 'smtp' and fill in host/credentials to deliver.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="worship@ai-church.local"
MAIL_FROM_NAME="AI Church"

# --- Frontend origin (used for links in outbound mail) ---
FRONTEND_URL=http://localhost:5173

# --- Account activation / email verification ---
# Tokens granted to a Member on activation (and on each monthly refill).
MEMBER_MONTHLY_TOKENS=100
# How long an activation link stays valid before the hourly cleanup removes the
# still-pending account.
EMAIL_VERIFICATION_EXPIRES_HOURS=24
# Admin-created users: false = active immediately + granted package; true = must
# verify by email like a self-service registrant.
ADMIN_USERS_REQUIRE_VERIFICATION=false

# --- Local MMS speech service used by Voice Studio status/transcript checks ---
MMS_SPEECH_URL=http://127.0.0.1:8003
MMS_ASR_TIMEOUT=300

# --- Automatic Voice Studio fine-tuning ---
VOICE_TRAIN_ENABLED=true
VOICE_TRAIN_WINDOW_START=02:00
VOICE_TRAIN_WINDOW_END=06:00
VOICE_TRAIN_MAX_LOAD=2.0
VOICE_TRAIN_MIN_CLIPS=300
VOICE_TRAIN_MIN_NEW_CLIPS=25
VOICE_TRAIN_COMMAND=/opt/ai-church/workers/tools/run_mms_vits_finetune.sh
VOICE_TRAIN_EPOCHS=120
VOICE_TRAIN_BATCH_SIZE=8
VOICE_TRAIN_LEARNING_RATE=2e-5

# AI chord detection for the song lyrics editor (optional, manual entry always works).
# Model id or endpoint used when "AI chord detection" is enabled in admin Settings.
AI_CHORD_MODEL=

# --- Knowledge RAG rollout ---
# Keep false until the worker embedding endpoint and Qdrant collection verify cleanly.
KNOWLEDGE_ENABLED=false
KNOWLEDGE_EMBEDDING=worker
KNOWLEDGE_EMBEDDING_DIMS=384
KNOWLEDGE_WORKER_URL=http://worker:8001
KNOWLEDGE_VECTOR=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
KNOWLEDGE_VERIFY_COLLECTION=knowledge_chunks
