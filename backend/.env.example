APP_NAME="AI Church"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_church
DB_USERNAME=ai_church
DB_PASSWORD=

# --- Sessions / Cache (file = no extra tables needed) ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file

# --- Queue (Redis via predis) ---
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1
